# Kiri OS Production — secrets
# Copy to .env and fill in values

# Ollama Cloud API
OLLAMA_API_KEY=

# Discord (Kiri bot) — Hermes expects DISCORD_BOT_TOKEN
DISCORD_BOT_TOKEN=

# Allow all Discord users to message Kiri (set false to restrict to allowlist)
GATEWAY_ALLOW_ALL_USERS=true

# Ollama endpoint (Ollama Cloud default)
OLLAMA_BASE_URL=https://ollama.com/v1
